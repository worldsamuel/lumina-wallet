generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  worldId     String?   @unique
  address     String    @unique
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?
}

model Token {
  id           String   @id @default(cuid())
  symbol       String   @unique
  name         String
  contractAddr String?  @unique
  poolAddress  String?
  decimals     Int      @default(18)
  logoUrl      String?
  status       String   @default("pending")
  tier         String   @default("community")
  canTransfer  Boolean  @default(true)
  canSwap      Boolean  @default(true)
  onTopRanking Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Announcement {
  id          Int      @id @default(autoincrement())
  tag         String
  titleI18n   Json
  bodyI18n    Json
  publishedAt DateTime @default(now())
}

model ContentPage {
  key      String   @id
  bodyI18n Json
  updatedAt DateTime @updatedAt
}

model FeeConfig {
  businessType String   @id
  percent      Decimal  @db.Decimal(5, 4)
  recipient    String?
  updatedAt    DateTime @updatedAt
}

model CurrencyRate {
  code      String   @id
  name      String
  symbol    String
  rate      Decimal  @db.Decimal(20, 8)
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         String    @default("admin")
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   String
  action    String
  target    String?
  payload   Json?
  createdAt DateTime @default(now())
}

model Feedback {
  id        Int      @id @default(autoincrement())
  address   String?
  username  String?
  contact   String?
  message   String
  status    String   @default("new")
  reply     String?
  repliedAt DateTime?
  repliedBy String?
  createdAt DateTime @default(now())
}
